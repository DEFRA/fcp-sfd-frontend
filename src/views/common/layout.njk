{% extends "govuk/template.njk" %}

{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}

{% from "common/heading/macro.njk" import appHeading %}
{% from "common/header/macro.njk" import appHeader %}
{% from "common/footer/macro.njk" import appFooter %}
{% set mainClasses = "app-main-wrapper" %}

{% block head %}
  <link rel="icon" href="{{ getAssetPath('assets/images/favicon.png') }}?v=1">
  <link rel="apple-touch-icon" href="{{ getAssetPath('assets/images/favicon.png') }}?v=1">

  <link href="{{ getAssetPath('stylesheets/application.scss') }}" rel="stylesheet">

  {% if metaDescription %}
    <meta name="description" content="{{ metaDescription }}">
  {% endif %}
{% endblock %}

{% block header %}
  {{ appHeader() }}

  {{ govukServiceNavigation({
    serviceName: serviceName,
    serviceUrl: serviceUrl
  }) }}

  <div class="govuk-width-container">
    {% include "common/phase-banner/phase-banner.njk" %}
  </div>
{% endblock %}

{% block pageTitle %}
  {% if pageTitle %}
    {{ pageTitle }} | {{ serviceName }}
  {% else %}
    {{ serviceName }}
  {% endif %}
{% endblock %}

{% block content %}{% endblock %}

{% block footer %}
  {{ appFooter({
    meta: {
      items: [
        {
          href: "/contact-help",
          text: "Contact us"
        },
        {
          href: "/cookies",
          text: "Cookies"
        },
        {
          href: "/accessibility-statement",
          text: "Accessibility statement"
        },
        {
          href: "https://www.gov.uk/government/organisations/rural-payments-agency/about/personal-information-charter",
          text: "Personal Information Charter",
          attributes: {
            target: "_blank",
            rel: "noopener noreferrer"
          }
        }
      ]
    }
  }) }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" nonce="{{ nonce }}" src="{{ getAssetPath('application.js') }}"></script>
{% endblock %}

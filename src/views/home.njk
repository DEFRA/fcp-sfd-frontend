{% extends 'common/layout.njk' %}
{% from "components/service-card/macro.njk" import serviceCard %}

{% block beforeContent %}
  <div class="govuk-grid-row sub-header-container govuk-!-padding-top-3">
    {% if backLink %}
      {% from "govuk/components/back-link/macro.njk" import govukBackLink %}
      <div class="govuk-grid-column-two-thirds">
        {{ govukBackLink({
          text: backLink.text,
          href: backLink.href,
          classes: "govuk-!-margin-top-0"
        }) }}
      </div>
    {% endif %}

    {% if auth.isAuthenticated %}
      <div class="
        govuk-grid-column-{% if backLink %}one-third{% else %}full{% endif %}
        govuk-!-text-align-right
      ">
        <a href="/auth/sign-out" class="govuk-link govuk-link--no-visited-state">Sign out</a>
      </div>
    {% endif %}
  </div>
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <span class="govuk-caption-xl text-wrap-no-hyphen">{{ userName }}</span>
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-2 text-wrap-no-hyphen">{{ businessName }}</h1>
    <p class="govuk-caption-m">Single business identifier (SBI): {{ sbi }}</p>
  </div>
</div>

{% if isOnFarmingPaymentsAllowList %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-m">Apply for schemes and grants</h2>
    </div>
  </div>

  {{ serviceCard({
    title: farmingPayments.title,
    status: farmingPayments.status,
    link: farmingPayments.link
  }) }}
{% endif %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h3 class="govuk-heading-m">Business details</h3>
    <p>
      <a href="{{ businessDetails.link }}" class="govuk-link govuk-link--no-visited-state">{{ businessDetails.text }}</a>
    </p>

    <h3 class="govuk-heading-m">Personal details</h3>
    <p>
      <a href="/personal-details" class="govuk-link govuk-link--no-visited-state">View and update your personal details</a>
    </p>
  </div>
</div>
{% endblock %}
